pipeline {
  agent {
    docker {
      image 'rithi0/maven-docker-agent:java17'
      args '-v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  options {
    skipDefaultCheckout(true)
  }

  stages {

    // ✅ 1. Checkout Code (FIXED)
    stage('Checkout') {
      steps {
        git branch: 'main', url: 'https://github.com/rithish-nakirikanti1/jenkins_project.git'
      }
    }

    // ✅ 2. Verify (Debug - optional)
    stage('Verify Workspace') {
      steps {
        sh '''
        echo "Current directory:"
        pwd
        echo "Files:"
        ls -la
        '''
      }
    }

    // ✅ 3. Build & Test
    stage('Build and Test') {
      steps {
        sh '''
        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
        mvn clean package
        '''
      }
    }

    // ✅ 4. SonarQube Analysis
    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://13.201.180.106:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh '''
          cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
          mvn sonar:sonar \
            -Dsonar.login=$SONAR_AUTH_TOKEN \
            -Dsonar.host.url=${SONAR_URL}
          '''
        }
      }
    }

    // ✅ 5. Build & Push Docker Image
    stage('Build and Push Docker Image') {
      environment {
        DOCKER_IMAGE = "rithi0/ultimate-cicd:${BUILD_NUMBER}"
      }
      steps {
        script {
          sh '''
          cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
          docker build -t ${DOCKER_IMAGE} .
          '''

          def dockerImage = docker.image("${DOCKER_IMAGE}")

          docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
            dockerImage.push()
          }
        }
      }
    }

    // ✅ 6. Update Deployment YAML (FIXED)
    stage('Update Deployment File') {
      environment {
        GIT_REPO_NAME = "jenkins_project"
        GIT_USER_NAME = "rithish-nakirikanti1"
      }
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
          # Ensure we are in git repo
          pwd
          ls -la

          git config user.email "rithishnakirikanti720@gmail.com"
          git config user.name "rithish-nakirikanti1"

          # Replace image tag
          sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

          # Commit changes
          git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
          git commit -m "Update deployment image to version ${BUILD_NUMBER}" || echo "No changes"

          # Push changes
          git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
          '''
        }
      }
    }
  }
}
